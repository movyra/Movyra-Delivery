rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // GLOBAL DENY
    // Strictly block all access by default to prevent data leaks.
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ========================================================================
    // ISOLATED APP ENVIRONMENT (New Structure)
    // All new API data is securely scoped within the unique artifacts/appId/ path.
    // ========================================================================
    match /artifacts/{appId} {

      match /users/{userId} {
        // 1. Grant access to the root user identity document
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // 2. Grant access to ALL nested private data using wildcard
        match /{document=**} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      match /public/data {
        // Driver transparency profiles are read-only
        match /drivers/{driverId} {
          allow read: if request.auth != null;
          allow write: if false;
        }

        // System telemetry logs are strictly append-only
        match /system_logs/{logId} {
          allow create: if true; 
          allow read, update, delete: if false;
        }
      }
    }

    // ========================================================================
    // LEGACY ROOT COLLECTIONS (Bridge for UI Inline Queries)
    // Prevents MobileHome.jsx and older components from crashing during migration.
    // ========================================================================
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
    }

    match /saved_addresses/{addressId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }

    match /bids/{bidId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }

    match /shipments/{shipmentId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }
    
    match /disputes/{disputeId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }
  }
}