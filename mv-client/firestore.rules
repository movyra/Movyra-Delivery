service cloud.firestore {
match /databases/{database}/documents {

// ========================================================================
// GLOBAL DENY
// Strictly block all access by default to prevent data leaks.
// ========================================================================
match /{document=**} {
  allow read, write: if false;
}

// ========================================================================
// USERS COLLECTION
// Users can only read and write to their own profile document.
// Matches the UID of the authenticated user to the document ID.
// ========================================================================
match /users/{userId} {
  allow read, write: if request.auth != null && request.auth.uid == userId;
}

// ========================================================================
// SHIPMENTS COLLECTION
// Protects order history and active bookings.
// Validates that the 'userId' field on the document matches the auth token.
// ========================================================================
match /shipments/{shipmentId} {
  // Allow creation only if the user is assigning their own UID to the document
  allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
  // Allow read/update/delete only if the existing document belongs to the user
  allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
}

// ========================================================================
// TRACKING HISTORY COLLECTION
// Secures the recent search history for the Live Tracking dashboard.
// ========================================================================
match /tracking_history/{trackingId} {
  allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
  allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
}


}
}