rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // GLOBAL DENY
    // Strictly block all access by default to prevent data leaks.
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ========================================================================
    // ISOLATED APP ENVIRONMENT
    // All data is securely scoped within the unique artifacts/appId/ path.
    // ========================================================================
    match /artifacts/{appId} {

      // ========================================================================
      // PRIVATE USER DATA (Address Book, Profile, Disputes, Orders)
      // Validates that the UID in the path strictly matches the active Auth token.
      // ========================================================================
      match /users/{userId} {
        
        // 1. Grant access to the root user identity document
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // 2. Grant access to all 1st-level private subcollections (saved_addresses, disputes, orders)
        match /{subcollection}/{documentId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
        
        // 3. Grant access to 2nd-level nested data (profile/data)
        match /{subcollection}/{documentId}/{nestedSub}/{nestedDoc} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // ========================================================================
      // PUBLIC DATA BUCKET (Marketplace Drivers, Telemetry)
      // ========================================================================
      match /public/data {
        
        // Driver transparency profiles are read-only for authenticated users
        match /drivers/{driverId} {
          allow read: if request.auth != null;
          allow write: if false;
        }

        // System telemetry and crash logs are strictly append-only
        match /system_logs/{logId} {
          allow create: if true; 
          allow read, update, delete: if false;
        }
      }
    }
  }
}