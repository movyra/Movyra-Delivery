# ==============================================================================
# MOVYRA BACKEND - RUST AXUM SERVER CONFIGURATION (STRICT PRODUCTION)
# ==============================================================================

# Server Network Configuration
PORT=8080
HOST=0.0.0.0

# Database Connection String
# FIX: Appending the Project ID to the username (postgres.nlwysrvkaigcamzmljer) 
# is strictly required by the Supabase IPv4 Pooler to resolve the Tenant error.
DATABASE_URL=postgresql://postgres.nlwysrvkaigcamzmljer:AXEcK9FeKl9N1Ms2@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# Redis Connection String (Upstash)
# Strictly configured with rediss:// for TLS requirements.
REDIS_URL=rediss://default:gQAAAAAAAQ-TAAIncDE0MjliZGZjZGIyNDY0ZWFiYjQ0YjdjNjNlNWMwNTRmOXAxNjk1MjM@kind-bison-69523.upstash.io:6379

# JWT Security
# Securely generated 256-bit key for signing session tokens.
JWT_SECRET=HzU4NN4PCx0OqIIW8ZW9yuYueYzoHeZpWbrOggE9JFo=

# OSRM / Mapping Engine
OSRM_BASE_URL=http://router.project-osrm.org

# ==============================================================================
# NEW SECTION 1: Firebase Authentication (JWT Validation)
# Required for Rust to verify Google's cryptographic signatures and tokens.
# ==============================================================================
FIREBASE_PROJECT_ID=movyra-customer-prod
GOOGLE_CERTS_URL=https://www.googleapis.com/robot/v1/metadata/x509/securetoken@system.gserviceaccount.com

# ==============================================================================
# NEW SECTION 2: Logging & Telemetry Engine
# Controls the `tracing` crate output levels for Axum and SQLx query debugging.
# ==============================================================================
RUST_LOG=info,mv_backend=debug,axum::rejection=trace,sqlx=warn
RUST_BACKTRACE=1

# ==============================================================================
# NEW SECTION 3: Database Connection Pool Guardrails
# Prevents Supabase Postgres connection exhaustion under high mobile app traffic.
# ==============================================================================
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2
DATABASE_ACQUIRE_TIMEOUT_SEC=10

# ==============================================================================
# NEW SECTION 4: CORS & Web Security
# Whitelisted frontend origins allowed to communicate with this Rust API.
# ==============================================================================
ALLOWED_ORIGINS=https://movyra-client.vercel.app,http://localhost:5173,https://movyra.app

# ==============================================================================
# NEW SECTION 5: API Rate Limiting (Anti-DDoS)
# Limits for the Axum sliding-window rate limiter per IP address.
# ==============================================================================
RATE_LIMIT_REQUESTS_PER_MIN=120