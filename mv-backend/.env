# ==============================================================================
# MOVYRA BACKEND - RUST AXUM SERVER CONFIGURATION
# ==============================================================================

# Server Network Configuration
# The port the Axum server will bind to.
PORT=8080
HOST=0.0.0.0

# Database Connection String (PostgreSQL via Supabase)
# Replace [USER], [PASSWORD], [PROJECT_REF], and [REGION] with actual Supabase details.
# Strict native-tls connection string for SQLx.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.nlwysrvkaigcamzmljer.supabase.co:5432/postgres

# Redis Connection String (Upstash)
# Used for real-time driver tracking caches and pub/sub matching queues.
# Replace [PASSWORD], [ENDPOINT], and [PORT] with actual Upstash details.
REDIS_URL=rediss://default:[YOUR_PASSWORD]@[YOUR_UPSTASH_ENDPOINT]:[PORT]

# JWT Security
# Strictly generated secure token used for signing and verifying JSON Web Tokens internally.
# Run `openssl rand -base64 32` in terminal to generate a production-ready key.
JWT_SECRET=YOUR_SECURE_RANDOMLY_GENERATED_JWT_SECRET_STRING_HERE

# OSRM / Mapping Engine
# Endpoint for distance/route calculations (Using public OSRM for dev, use self-hosted or Mapbox for prod).
OSRM_BASE_URL=http://router.project-osrm.org